NEXT_PUBLIC_SITE_URL=https://example.com

# Resend API key, used by the "Work with me" enquiry form's Server Action to
# email submissions. Create one at https://resend.com/api-keys. The sending
# domain (the address in the email's "from") must be verified in Resend.
RESEND_API_KEY=

# Upstash Redis credentials, used to rate-limit the enquiry form (per-IP and a
# global daily cap). Optional: when unset, the form still sends but is not
# throttled. Create a free database at https://console.upstash.com/.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
